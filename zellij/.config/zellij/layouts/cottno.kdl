layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
    }
    tab cwd="~/projects/cottno-api" name="1 nvim" {
        pane command="nvim"
    }

    tab cwd="~/projects/cottno-api/src/web" name="2 dotnet" {
        pane
    }

    tab cwd="~/projects/cottno-api/src/cottno" name="3 pnpm" {
        pane
    }

    tab cwd="~/projects/cottno-api" name="4 terminal" {
        pane
    }
}
